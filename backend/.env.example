# Database Configuration
MONGODB_URI=mongodb://localhost:27017/pulse-talent
# Or use MongoDB Atlas
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pulse-talent

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
JWT_EXPIRE=7d

# File Upload Configuration
MAX_FILE_SIZE=500000000
UPLOAD_DIR=./uploads

# Video Processing
# Optional for future real video processing. The current app uses mock analysis.
FFMPEG_PATH=ffmpeg
ENABLE_SENSITIVITY_ANALYSIS=true

# Sensitivity Analysis API
# No real API key is required right now; analysis is mocked in src/services/sensitivityService.js.
SENSITIVITY_API_URL=mock
SENSITIVITY_API_KEY=test_key

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Socket.io Configuration
SOCKET_IO_CORS=http://localhost:5173
